FROM golang:1.26-bookworm

WORKDIR /workspace

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates python3 python3-pip python3-venv \
  && rm -rf /var/lib/apt/lists/*

RUN go install github.com/air-verse/air@v1.65.3

COPY platform ./platform
COPY argos ./argos

RUN python3 -m venv /opt/argos-processing-venv \
  && /opt/argos-processing-venv/bin/pip install --no-cache-dir -e /workspace/argos/processing/python

WORKDIR /workspace/argos/core
RUN go mod download

ENV PORT=8080
ENV ARGOS_STORAGE_DIR=/data/outputs
ENV ARGOS_PROCESSING_PYTHON=/opt/argos-processing-venv/bin/python
ENV ARGOS_PROCESSING_PYTHONPATH=/workspace/argos/processing/python
ENV ARGOS_PROCESSING_TIMEOUT_SEC=180

CMD ["air"]
