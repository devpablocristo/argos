ARGOS_CORE_PORT=18090
ARGOS_UI_PORT=13003
ARGOS_POSTGRES_PORT=15436

ARGOS_POSTGRES_DB=argos
ARGOS_POSTGRES_USER=postgres
ARGOS_POSTGRES_PASSWORD=postgres
ARGOS_DATABASE_URL=postgres://postgres:postgres@argos-postgres:5432/argos?sslmode=disable

ARGOS_STORAGE_DIR=/data/outputs
ARGOS_PROCESSING_PYTHON=/opt/argos-processing-venv/bin/python
ARGOS_PROCESSING_PYTHONPATH=/workspace/argos/processing/python
ARGOS_PROCESSING_TIMEOUT_SEC=180

ARGOS_ORG_ID=argos-local-org
ARGOS_NEXUS_BASE_URL=http://nexus:8080
ARGOS_NEXUS_API_KEY=argos-nexus-dev-key
ARGOS_COMPANION_BASE_URL=http://companion:8080
ARGOS_COMPANION_API_KEY=argos-companion-dev-key
ARGOS_PUBLIC_BASE_URL=http://localhost:13003

VITE_ARGOS_DEFAULT_SOURCE_URI=/data/sample
